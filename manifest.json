{
  "manifest_version": 3,
  "name": "ClassPlus Organizer Pro",
  "version": "2.1.0",
  "description": "Premium lecture navigator: instant search, lecture numbers, range nav, jump-to-lecture, dark/light mode, and smart organization for ClassPlus courses.",
  "permissions": [
    "storage",
    "webRequest",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.classplusapp.com/*",
    "https://web.classplusapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.classplusapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClassPlus Organizer Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fuse.min.js"
      ],
      "matches": [
        "https://web.classplusapp.com/*"
      ]
    }
  ]
}